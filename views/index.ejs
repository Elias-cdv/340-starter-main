<main class="home-view">
  <h1>Welcome to CSE Motors!</h1>

  <section class="hero-container">
    <div class="hero-text">
      <h2>DMC Delorean</h2>
      <p>
        3-cup holders<br />
        Superman doors<br />
        Fuzzy dice!
      </p>
      <button class="own-today">Own Today</button>
    </div>
    <img src="/images/delorean.jpg" alt="DMC Delorean" />
  </section>

  <div class="flex-content">
    <section class="reviews">
      <h3>DMC Delorean Reviews</h3>
      <ul>
        <li>"So fast, its almost like traveling in time." (4/5)</li>
        <li>"With cool stuff like this, who needs friends?" (5/5)</li>
        <li>"I'm feeling Blue." (4/5)</li>
        <li>"Enjoying my 3-cup holders!" (5/5)</li>
        <li>"Is't the most futuristic ride of our day." (4.5/5)</li>
      </ul>
    </section>

    <section class="upgrades">
      <h3>Delorean Upgrades</h3>
      <div class="upgrade-grid">
        <div class="upgrade-item">
          <div class="upgrade-img-box">
            <img src="/images/upgrades/flux-cap.png" alt="Flux Capacitor" />
          </div>
          <a href="#">Flux Capacitor</a>
        </div>
        <div class="upgrade-item">
          <div class="upgrade-img-box">
            <img src="/images/upgrades/flame.png" alt="Flame Decals" />
          </div>
          <a href="#">Flame Decals</a>
        </div>
        <div class="upgrade-item">
          <div class="upgrade-img-box">
            <img
              src="/images/upgrades/bumper_sticker.png"
              alt="Bumper Sticker"
            />
          </div>
          <a href="#">Bumper Sticker</a>
        </div>
        <div class="upgrade-item">
          <div class="upgrade-img-box">
            <img src="/images/upgrades/hub-cap.png" alt="Hub Caps" />
          </div>
          <a href="#">Hub Caps</a>
        </div>
      </div>
    </section>
  </div>
</main>

<main class="home-view">
  <h1>Welcome to CSE Motors!</h1>

  <section class="hero-container">
    <div class="hero-text">
      <h2>DMC Delorean</h2>
      <p>
        3-cup holders<br />
        Superman doors<br />
        Fuzzy dice!
      </p>
      <a href="#" class="own-today">Own Today</a>
    </div>
    <img
      src="/images/vehicles/delorean.jpg"
      alt="DMC Delorean - silver sports car with gull-wing doors"
    />
  </section>

  <div class="flex-content">
    <section class="reviews">
      <h3>DMC Delorean Reviews</h3>
      <ul>
        <li>"So fast, its almost like traveling in time." (4/5)</li>
        <li>"With cool stuff like this, who needs friends?" (5/5)</li>
        <li>"I'm feeling Blue." (4/5)</li>
        <li>"Enjoying my 3-cup holders!" (5/5)</li>
        <li>"It's the most futuristic ride of our day." (4.5/5)</li>
      </ul>
    </section>

    <section class="upgrades">
      <h3>Delorean Upgrades</h3>
      <div class="upgrade-grid">
        <div class="upgrade-item">
          <img
            src="/images/upgrades/flux-cap.png"
            alt="Flux Capacitor upgrade"
          />
          <a href="#">Flux Capacitor</a>
        </div>
        <div class="upgrade-item">
          <img src="/images/upgrades/flame.jpg" alt="Flame Decals upgrade" />
          <a href="#">Flame Decals</a>
        </div>
        <div class="upgrade-item">
          <img
            src="/images/upgrades/bumper_sticker.jpg"
            alt="Bumper Sticker upgrade"
          />
          <a href="#">Bumper Sticker</a>
        </div>
        <div class="upgrade-item">
          <img src="/images/upgrades/hub-cap.jpg" alt="Hub Caps upgrade" />
          <a href="#">Hub Caps</a>
        </div>
      </div>
    </section>
  </div>
</main>

<h1><%= title %></h1>
<%- messages() %>

<div class="management-links">
  <ul>
    <li><a href="/inv/add-classification">Add New Classification</a></li>
    <li><a href="/inv/add-inventory">Add New Vehicle</a></li>
  </ul>

  <h2>Manage Inventory</h2>
  <p>Select a classification to see items.</p>
  <%- classificationSelect %>
  <table id="inventoryDisplay"></table>
  <noscript>JavaScript must be enabled.</noscript>
</div>

<hr>

<div class="review-test" style="background: #f0f0f0; padding: 20px; border: 1px solid #ccc;">
    <h2>Test Reviews System</h2>
    <% if (locals.loggedin) { %>
        <form action="/review/add" method="post">
            <textarea name="review_text" rows="4" style="width:100%" required placeholder="Escribe algo aquí..."></textarea>
            <input type="hidden" name="inv_id" value="1"> 
            <input type="hidden" name="account_id" value="<%= locals.accountData.account_id %>">
            <br><button type="submit">Enviar Reseña de Prueba</button>
        </form>
    <% } else { %>
        <p>Debes estar <a href="/account/login">logueado</a> para probar reseñas.</p>
    <% } %>
</div>

<script src="../../js/inventory.js"></script>